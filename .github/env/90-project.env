# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-bitcoin
# Load Order: 90 (loaded late, overrides defaults from earlier files)
#
# This file contains project-specific configuration that overrides defaults
# defined in the core and tool-specific env files (00-core, 10-*, 20-*).
#
# Use this file for values unique to this project such as:
# - Go version overrides for compatibility testing
# - Coverage provider and threshold overrides
# - Custom exclusion paths
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X GO VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE OVERRIDES
# ================================================================================================

# Coverage report provider (overrides default: internal)
GO_COVERAGE_PROVIDER=codecov

# Codecov token required (overrides default: false)
CODECOV_TOKEN_REQUIRED=true

# Coverage threshold (overrides default: 65.0)
GO_COVERAGE_THRESHOLD=55.0

# ================================================================================================
# 🛡️ CVE EXCLUSION OVERRIDES
# ================================================================================================

# Custom exclusions for AskNancy vulnerability scanning
NANCY_EXCLUDES=CVE-2026-5932

# Custom exclusions for Govulncheck/Magex vulnerability scanning
MAGE_X_CVE_EXCLUDES=GO-2026-5932
